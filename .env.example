NEXT_PUBLIC_APP_URL=http://localhost:3000

# MySQL local, server-side only. Do not prefix with NEXT_PUBLIC_.
DATABASE_URL="mysql://diagnosi_user:diagnosi_password@127.0.0.1:3306/diagnosi_ia"

PRIVATE_TOKEN_HMAC_SECRET=replace-with-strong-random-secret
RESULTS_TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64url-key

# Provisional local auth for migration/mysql development only.
# Use AUTH_MODE=local for local bypass, or AUTH_MODE=google for real Google OAuth.
AUTH_MODE=local
LOCAL_AUTH_USER_ID=00000000-0000-4000-8000-000000000001
LOCAL_AUTH_EMAIL=usuari.prova@xtec.cat
# Only for verifying `npm start` locally. Do not enable on a real server.
LOCAL_AUTH_ALLOW_PRODUCTION=false

# Google OAuth without Supabase. Required when AUTH_MODE=google.
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters
# Keep this stable: changing it changes the opaque owner/admin ids derived from Google.
AUTH_USER_ID_SECRET=replace-with-at-least-32-random-characters
# Optional. Defaults to AUTH_USER_ID_SECRET. Rotating it allows accounts to answer again.
SUBMISSION_LOCK_HMAC_SECRET=replace-with-at-least-32-random-characters
AUTH_SESSION_MAX_AGE_SECONDS=28800
